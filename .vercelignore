# ============================================================================
# Repo-root .vercelignore — keep the Vercel upload lean + under the 100 MB/file cap
# ============================================================================
# We run `vercel --prod` from the repo ROOT, so Vercel applies THIS file (the
# nested nidham/.vercelignore only applies when deploying from nidham/). The
# Next.js app that Vercel builds lives in nidham/; everything below is
# irrelevant to that build — companion apps, native binaries, build artifacts,
# and the other projects in this folder. Vercel does NOT honor nested
# .gitignore files, so the heavy dirs must be listed explicitly here.

# Electron desktop client + its huge build outputs (Setup.exe / .nupkg / win32
# package — each >100 MB, which is what broke the deploy).
nidham/desktop

# On-prem Docker edition + mobile app — not part of the web build.
nidham/enterprise
nidham/mobile

# Separate / companion projects living in the same folder.
hr-mostashar
frontend
backend

# Build outputs & caches (regenerated by Vercel).
out
.next
dist
build
*.tsbuildinfo

# Dev-only artifacts.
coverage
test-results
playwright-report
.claude
