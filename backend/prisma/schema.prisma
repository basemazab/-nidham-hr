generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Multi-Company / Multi-Factory
// ============================================================

model Company {
  id            String   @id @default(uuid())
  nameAr        String   @map("name_ar")
  nameEn        String   @map("name_en")
  logoUrl       String?  @map("logo_url")
  primaryColor  String?  @default("#0D1B2A") @map("primary_color")
  accentColor   String?  @default("#C9A84C") @map("accent_color")
  taxId         String?  @map("tax_id")
  socialInsuranceNumber String? @map("social_insurance_number")
  address       String?
  phone         String?
  email         String?
  workDaysPerWeek Int    @default(6) @map("work_days_per_week")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  factories     Factory[]
  departments   Department[]
  employees     Employee[]
  payrollRuns   PayrollRun[]
  users         UserCompany[]
  allowanceConfigs AllowanceConfig[]

  @@map("companies")
}

model Factory {
  id        String   @id @default(uuid())
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  address   String?
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[]
  shifts    Shift[]

  @@map("factories")
}

model Department {
  id        String   @id @default(uuid())
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  positions Position[]
  employees Employee[]

  @@map("departments")
}

model Position {
  id           String   @id @default(uuid())
  nameAr       String   @map("name_ar")
  nameEn       String   @map("name_en")
  departmentId String   @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employees Employee[]

  @@map("positions")
}

// ============================================================
// Auth & RBAC
// ============================================================

enum UserRole {
  SUPER_ADMIN
  HR_MANAGER
  HR_OFFICER
  MANAGER
  EMPLOYEE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String   @map("password_hash")
  nameAr        String   @map("name_ar")
  nameEn        String   @map("name_en")
  role          UserRole @default(EMPLOYEE)
  isActive      Boolean  @default(true) @map("is_active")
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret")
  employeeId    String?  @unique @map("employee_id")
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  companies     UserCompany[]
  auditLogs     AuditLog[]

  @@map("users")
}

model UserCompany {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id])
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  isDefault Boolean @default(false) @map("is_default")

  @@unique([userId, companyId])
  @@map("user_companies")
}

// ============================================================
// Employee Master Data
// ============================================================

enum EmployeeCategory {
  MONTHLY
  WEEKLY
  HOURLY
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  TEMPORARY
  PROBATION
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

model Employee {
  id                String   @id @default(uuid())
  employeeCode      String   @unique @map("employee_code")
  // Personal Info
  nameAr            String   @map("name_ar")
  nameEn            String   @map("name_en")
  nationalId        String   @unique @map("national_id") // encrypted at rest
  dateOfBirth       DateTime @map("date_of_birth")
  gender            String
  maritalStatus     MaritalStatus @default(SINGLE) @map("marital_status")
  dependentsCount   Int      @default(0) @map("dependents_count")
  phone             String?
  email             String?
  addressAr         String?  @map("address_ar")
  addressEn         String?  @map("address_en")
  photoUrl          String?  @map("photo_url")

  // Job Info
  companyId         String   @map("company_id")
  company           Company  @relation(fields: [companyId], references: [id])
  factoryId         String?  @map("factory_id")
  factory           Factory? @relation(fields: [factoryId], references: [id])
  departmentId      String   @map("department_id")
  department        Department @relation(fields: [departmentId], references: [id])
  positionId        String   @map("position_id")
  position          Position @relation(fields: [positionId], references: [id])
  hireDate          DateTime @map("hire_date")
  contractType      ContractType @default(PERMANENT) @map("contract_type")
  contractEndDate   DateTime? @map("contract_end_date")
  category          EmployeeCategory @default(MONTHLY)
  status            EmployeeStatus @default(ACTIVE)

  // Salary Info (encrypted)
  basicSalary       Decimal  @default(0) @map("basic_salary") @db.Decimal(12, 2)
  hourlyRate        Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  insurableSalary   Decimal  @default(0) @map("insurable_salary") @db.Decimal(12, 2)

  // Social Insurance
  socialInsuranceNumber String? @map("social_insurance_number")
  socialInsuranceDate   DateTime? @map("social_insurance_date")

  // Bank Info
  bankName          String?  @map("bank_name")
  bankAccountNumber String?  @map("bank_account_number")
  bankIban          String?  @map("bank_iban")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User?
  documents         Document[]
  attendanceRecords AttendanceRecord[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  payrollItems      PayrollItem[]
  loans             Loan[]
  disciplinaryActions DisciplinaryAction[]
  performanceReviews PerformanceReview[]
  shiftAssignments  ShiftAssignment[]

  @@map("employees")
}

model Document {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String   // national_id, contract, certificate, medical, etc.
  nameAr      String   @map("name_ar")
  nameEn      String?  @map("name_en")
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  isEncrypted Boolean  @default(true) @map("is_encrypted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("documents")
}

// ============================================================
// Attendance & Shifts
// ============================================================

enum ShiftType {
  MORNING
  EVENING
  NIGHT
  SPLIT
}

model Shift {
  id          String   @id @default(uuid())
  nameAr      String   @map("name_ar")
  nameEn      String   @map("name_en")
  type        ShiftType @default(MORNING)
  startTime   String   @map("start_time") // HH:mm format
  endTime     String   @map("end_time")
  breakMinutes Int     @default(60) @map("break_minutes")
  graceMinutes Int     @default(5) @map("grace_minutes")
  factoryId   String   @map("factory_id")
  factory     Factory  @relation(fields: [factoryId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assignments ShiftAssignment[]

  @@map("shifts")
}

model ShiftAssignment {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])
  shiftId    String   @map("shift_id")
  shift      Shift    @relation(fields: [shiftId], references: [id])
  startDate  DateTime @map("start_date")
  endDate    DateTime? @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("shift_assignments")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  ON_LEAVE
  HOLIDAY
  REST_DAY
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id])
  date          DateTime @db.Date
  checkIn       DateTime? @map("check_in")
  checkOut      DateTime? @map("check_out")
  status        AttendanceStatus @default(PRESENT)
  lateMinutes   Int      @default(0) @map("late_minutes")
  earlyLeaveMinutes Int  @default(0) @map("early_leave_minutes")
  overtimeMinutes   Int  @default(0) @map("overtime_minutes")
  workedHours   Decimal  @default(0) @map("worked_hours") @db.Decimal(5, 2)
  isManualCorrection Boolean @default(false) @map("is_manual_correction")
  correctionApprovedBy String? @map("correction_approved_by")
  notes         String?
  source        String   @default("zkteco") // zkteco, manual, import
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, date])
  @@map("attendance_records")
}

// ============================================================
// Leave Management
// ============================================================

enum LeaveType {
  ANNUAL
  CASUAL
  SICK
  MATERNITY
  HAJJ
  MARRIAGE
  BEREAVEMENT
  EXAM
  UNPAID
}

model LeaveBalance {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  leaveType   LeaveType @map("leave_type")
  year        Int
  entitled    Decimal  @default(0) @db.Decimal(5, 1) // total entitled days
  used        Decimal  @default(0) @db.Decimal(5, 1)
  carriedOver Decimal  @default(0) @map("carried_over") @db.Decimal(5, 1)
  remaining   Decimal  @default(0) @db.Decimal(5, 1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, leaveType, year])
  @@map("leave_balances")
}

enum LeaveRequestStatus {
  PENDING
  MANAGER_APPROVED
  HR_APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  leaveType   LeaveType @map("leave_type")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  days        Decimal  @db.Decimal(5, 1)
  reason      String?
  status      LeaveRequestStatus @default(PENDING)
  managerComment String? @map("manager_comment")
  hrComment   String?  @map("hr_comment")
  approvedBy  String?  @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  attachmentUrl String? @map("attachment_url") // medical certificate etc.
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("leave_requests")
}

// ============================================================
// Payroll Engine
// ============================================================

enum PayrollRunStatus {
  DRAFT
  PREVIEW
  COMMITTED
  PAID
}

model PayrollRun {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])
  month       Int      // 1-12
  year        Int
  status      PayrollRunStatus @default(DRAFT)
  totalGross  Decimal  @default(0) @map("total_gross") @db.Decimal(14, 2)
  totalNet    Decimal  @default(0) @map("total_net") @db.Decimal(14, 2)
  totalSocialInsuranceEmployee Decimal @default(0) @map("total_si_employee") @db.Decimal(14, 2)
  totalSocialInsuranceEmployer Decimal @default(0) @map("total_si_employer") @db.Decimal(14, 2)
  totalTax    Decimal  @default(0) @map("total_tax") @db.Decimal(14, 2)
  processedBy String?  @map("processed_by")
  committedAt DateTime? @map("committed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       PayrollItem[]

  @@unique([companyId, month, year])
  @@map("payroll_runs")
}

model PayrollItem {
  id                String   @id @default(uuid())
  payrollRunId      String   @map("payroll_run_id")
  payrollRun        PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId        String   @map("employee_id")
  employee          Employee @relation(fields: [employeeId], references: [id])

  // Earnings
  basicSalary       Decimal  @default(0) @map("basic_salary") @db.Decimal(12, 2)
  workedDays        Decimal  @default(0) @map("worked_days") @db.Decimal(5, 1)
  workedHours       Decimal  @default(0) @map("worked_hours") @db.Decimal(7, 2)
  transportAllowance Decimal @default(0) @map("transport_allowance") @db.Decimal(10, 2)
  mealAllowance     Decimal  @default(0) @map("meal_allowance") @db.Decimal(10, 2)
  housingAllowance  Decimal  @default(0) @map("housing_allowance") @db.Decimal(10, 2)
  performanceBonus  Decimal  @default(0) @map("performance_bonus") @db.Decimal(10, 2)
  overtimePay       Decimal  @default(0) @map("overtime_pay") @db.Decimal(10, 2)
  otherEarnings     Decimal  @default(0) @map("other_earnings") @db.Decimal(10, 2)
  grossSalary       Decimal  @default(0) @map("gross_salary") @db.Decimal(12, 2)

  // Deductions
  socialInsuranceEmployee Decimal @default(0) @map("si_employee") @db.Decimal(10, 2)
  socialInsuranceEmployer Decimal @default(0) @map("si_employer") @db.Decimal(10, 2)
  incomeTax         Decimal  @default(0) @map("income_tax") @db.Decimal(10, 2)
  loanDeduction     Decimal  @default(0) @map("loan_deduction") @db.Decimal(10, 2)
  advanceDeduction  Decimal  @default(0) @map("advance_deduction") @db.Decimal(10, 2)
  absenceDeduction  Decimal  @default(0) @map("absence_deduction") @db.Decimal(10, 2)
  lateDeduction     Decimal  @default(0) @map("late_deduction") @db.Decimal(10, 2)
  otherDeductions   Decimal  @default(0) @map("other_deductions") @db.Decimal(10, 2)
  totalDeductions   Decimal  @default(0) @map("total_deductions") @db.Decimal(12, 2)

  netSalary         Decimal  @default(0) @map("net_salary") @db.Decimal(12, 2)

  // Tax calculation details
  annualGross       Decimal  @default(0) @map("annual_gross") @db.Decimal(14, 2)
  annualSI          Decimal  @default(0) @map("annual_si") @db.Decimal(14, 2)
  annualTaxable     Decimal  @default(0) @map("annual_taxable") @db.Decimal(14, 2)
  annualTax         Decimal  @default(0) @map("annual_tax") @db.Decimal(14, 2)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([payrollRunId, employeeId])
  @@map("payroll_items")
}

// ============================================================
// Loans
// ============================================================

enum LoanStatus {
  ACTIVE
  PAID_OFF
  CANCELLED
}

model Loan {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  employee        Employee @relation(fields: [employeeId], references: [id])
  amount          Decimal  @db.Decimal(12, 2)
  monthlyInstallment Decimal @map("monthly_installment") @db.Decimal(10, 2)
  totalInstallments  Int   @map("total_installments")
  paidInstallments   Int   @default(0) @map("paid_installments")
  remainingBalance   Decimal @default(0) @map("remaining_balance") @db.Decimal(12, 2)
  status          LoanStatus @default(ACTIVE)
  reason          String?
  approvedBy      String?  @map("approved_by")
  startDate       DateTime @map("start_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("loans")
}

// ============================================================
// Allowance Configuration (per company)
// ============================================================

model AllowanceConfig {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id])
  category        EmployeeCategory
  transportAllowance Decimal @default(0) @map("transport_allowance") @db.Decimal(10, 2)
  mealAllowance   Decimal  @default(0) @map("meal_allowance") @db.Decimal(10, 2)
  housingAllowance Decimal @default(0) @map("housing_allowance") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([companyId, category])
  @@map("allowance_configs")
}

// ============================================================
// Disciplinary Actions
// ============================================================

enum DisciplinaryLevel {
  VERBAL_WARNING
  WRITTEN_WARNING
  ONE_DAY_DEDUCTION
  THREE_DAY_DEDUCTION
  FIVE_DAY_DEDUCTION
  TERMINATION
}

model DisciplinaryAction {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  level       DisciplinaryLevel
  reason      String
  details     String?
  date        DateTime @db.Date
  issuedBy    String   @map("issued_by")
  letterUrl   String?  @map("letter_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("disciplinary_actions")
}

// ============================================================
// Performance Management
// ============================================================

enum ReviewPeriod {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
}

model PerformanceReview {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  period      ReviewPeriod @default(ANNUAL)
  year        Int
  overallRating Decimal @default(0) @map("overall_rating") @db.Decimal(3, 1)
  strengths   String?
  improvements String?
  goals       String?
  reviewerComment String? @map("reviewer_comment")
  employeeComment String? @map("employee_comment")
  reviewedBy  String   @map("reviewed_by")
  reviewDate  DateTime @map("review_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  kpis        PerformanceKPI[]

  @@map("performance_reviews")
}

model PerformanceKPI {
  id          String   @id @default(uuid())
  reviewId    String   @map("review_id")
  review      PerformanceReview @relation(fields: [reviewId], references: [id])
  nameAr      String   @map("name_ar")
  nameEn      String?  @map("name_en")
  weight      Decimal  @db.Decimal(5, 2) // percentage
  target      String?
  actual      String?
  rating      Decimal  @default(0) @db.Decimal(3, 1)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("performance_kpis")
}

// ============================================================
// Recruitment
// ============================================================

enum CandidateStatus {
  APPLIED
  SCREENED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model JobPosting {
  id          String   @id @default(uuid())
  titleAr     String   @map("title_ar")
  titleEn     String   @map("title_en")
  descriptionAr String @map("description_ar")
  descriptionEn String? @map("description_en")
  departmentId String  @map("department_id")
  isInternal  Boolean  @default(false) @map("is_internal")
  isActive    Boolean  @default(true) @map("is_active")
  publicSlug  String?  @unique @map("public_slug")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  candidates  Candidate[]

  @@map("job_postings")
}

model Candidate {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  job         JobPosting @relation(fields: [jobId], references: [id])
  nameAr      String   @map("name_ar")
  nameEn      String?  @map("name_en")
  email       String
  phone       String?
  cvUrl       String?  @map("cv_url")
  status      CandidateStatus @default(APPLIED)
  notes       String?
  interviewDate DateTime? @map("interview_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("candidates")
}

// ============================================================
// Audit Log
// ============================================================

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  action      String   // CREATE, UPDATE, DELETE
  entity      String   // employee, payroll, leave, etc.
  entityId    String   @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
