# Application
APP_NAME="مستشار HR"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-in-production
API_PREFIX=/api

# Database
DATABASE_URL=sqlite+aiosqlite:///./hr_mostashar.db

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Rate Limiting
RATE_LIMIT_FREE_QUESTIONS_PER_MONTH=5
RATE_LIMIT_FREE_TEMPLATES_PER_MONTH=3

# Admin
ADMIN_EMAIL=admin@hrmostashar.com
ADMIN_PASSWORD=admin123

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Payment (Manual)
VODAFONE_CASH_NUMBER=010XXXXXXXX
INSTAPAY_NUMBER=010XXXXXXXX
BANK_ACCOUNT=XXXX-XXXX-XXXX-XXXX
BANK_NAME=Example Bank
