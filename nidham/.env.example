# ════════════════════════════════════════════════════════════════════
#  Nidham HR — environment variables (NAMES + placeholders only, NO real secrets)
#  Real values live in Vercel (Project → Settings → Environment Variables).
#  To run locally: copy needed vars into .env.local (gitignored). Pull from
#  Vercel with:  npx vercel env pull .env.local
#  Uncommented = required to boot. Commented = optional / feature-gated.
# ════════════════════════════════════════════════════════════════════

# ── Essential ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://whedifdmllooyejzuwrw.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...        # Supabase → Settings → API (NEVER commit the real one)
# SUPABASE_URL=https://...supabase.co          # server-side alias; read by lib/supabase/{server,public,middleware}.ts
GEMINI_API_KEY=AIzaSy...                       # Gemini — embeddings + AI fallback (aistudio.google.com/apikey)

# ── Security (REQUIRED for auth / 2FA — generate random base64url) ──
# JWT_SECRET=...                               # signs tokens. e.g. `openssl rand -base64 32`
# TWOFA_COOKIE_SECRET=...                      # signs the 2FA cookie. `openssl rand -base64 32`

# ── AI providers (fallback chain so AI never hard-stops on quota) ──
# GROQ_API_KEY=gsk_...                         # Groq — reliable tool-calling (مجاني، 30 RPM). console.groq.com/keys
# AI_AGENT_MODEL=groq:openai/gpt-oss-120b      # override default agent model
# --- NaraRouter: OpenAI-compatible gateway, ~7M tokens/day free, used as a fallback ---
# KEY_nara=sk-nry-...                          # Nara key. Code reads NARA_API_KEY first, else KEY_nara. In Vercel it is stored as KEY_nara.
# NARA_API_KEY=sk-nry-...                      # alternative name (takes precedence over KEY_nara if both set)
# NARA_MODEL=mistral-large                     # default. Free tier — do NOT use auto/bynara (404). Options: mistral-large, mistral-medium-3-5, mimo-v2.5-free

# ── Site URLs ──────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://www.nidhamhr.com   # canonical URL (emails, share links, OG, sitemaps)
# NEXT_PUBLIC_APP_URL=https://www.nidhamhr.com    # app base URL (alias used in a few routes)
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=...            # override desktop installer link (default: GitHub releases/latest)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=...             # Google Search Console verification token

# ── Email (Resend) ─────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@nidhamhr.com
# RESEND_REPLY_TO=support@nidhamhr.com
# MARKETING_FROM_EMAIL=marketing@nidhamhr.com   # optional sender override for marketing campaigns
# NIDHAM_SALES_EMAIL=sales@nidhamhr.com         # recipient for in-app sales / new-lead alert emails

# ── Lead generation / Scraping ─────────────────────────
# APIFY_API_TOKEN=apify_api_...                 # Apify scraping actors (console.apify.com → Settings → Integrations)
# APIFY_TOKEN=apify_api_...                     # alternative name for the same token

# ── Marketing (Meta / WhatsApp) ──────────────────────
# META_APP_ID=...
# META_APP_SECRET=...
# META_ENCRYPTION_KEY=...
# META_WEBHOOK_VERIFY_TOKEN=...
# WHATSAPP_ACCESS_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_VERIFY_TOKEN=...
# NEXT_PUBLIC_META_PIXEL_ID=...

# ── Push Notifications ────────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@nidhamhr.com

# ── Error Tracking ─────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...
# SENTRY_ORG=...
# SENTRY_PROJECT=...
# SENTRY_AUTH_TOKEN=...

# ── Automation / Cron ──────────────────────────────────
# CRON_SECRET=...                               # protects /api/cron/* endpoints

# ── Test Credentials ───────────────────────────────────
# NIDHAM_BASE_URL=http://localhost:3000
# NIDHAM_EMAIL=admin@test.com
# NIDHAM_PASSWORD=test123
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ── Auto-injected by the platform (do NOT set manually) ──
#   NODE_ENV, VERCEL_ENV, VERCEL_REGION, VERCEL_GIT_COMMIT_SHA
