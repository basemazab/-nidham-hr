# Copy to scripts/.env.local (or repo root .env.local) and fill in.
# Used by scripts/capture-screenshots.ts.

# Production / preview deployment of Nidham. Trailing slash optional.
NIDHAM_BASE_URL=https://nidhamhr.com

# Admin or HR account on that deployment. Must already exist + be
# linked to a company with some employees/payroll/jobs to capture.
NIDHAM_EMAIL=demo@nidham.app
NIDHAM_PASSWORD=replace-with-real-password
