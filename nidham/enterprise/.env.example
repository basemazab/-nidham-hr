# ============================================================================
# Nidham Enterprise Edition — environment template
#
# DO NOT commit the actual .env to source control. Copy this file to .env
# and then run:
#
#   node scripts/generate-keys.mjs
#
# which fills in POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY, SERVICE_ROLE_KEY.
# The values you fill in by hand are the URLs, the AI API key, and SMTP.
# ============================================================================

# ----- Database -------------------------------------------------------------
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ----- JWT keys (auto-generated by scripts/generate-keys.mjs) ---------------
JWT_SECRET=change-me
ANON_KEY=
SERVICE_ROLE_KEY=

# ----- URLs ----------------------------------------------------------------
# What the Nidham app sends back in emails + sees as its own origin.
# On a single-server install with LAN access, use the server's static IP:
#   SITE_URL=http://192.168.1.10:8000
# When you point a DNS name at the server, switch to that hostname.
SITE_URL=http://localhost:8000

# Comma-separated list of additional redirect URLs auth will allow
ADDITIONAL_REDIRECT_URLS=

# ----- Ports ---------------------------------------------------------------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
APP_PORT=3000

# ----- AI (Gemini) ---------------------------------------------------------
# CV screening still uses Google Gemini. Get a key from
# https://aistudio.google.com/apikey — same one you use for the cloud version.
# Leave blank to disable AI features on this install.
GEMINI_API_KEY=

# ----- SMTP (transactional email for auth / password reset) -----------------
# Leave MAILER_AUTOCONFIRM=true for the simplest install (signup is instant,
# no email required). Set to false + configure SMTP for production hardening.
MAILER_AUTOCONFIRM=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Nidham
